# --- Provider keys (Module 1) ---
# At least one is required to use /chat. The provider toggle disables options
# whose key is missing — set the ones you want to demo.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TOGETHER_API_KEY=

# --- LangSmith (Module 1+) ---
# Tracing is OFF by default. Flip LANGSMITH_TRACING=true and set the key to
# emit traces. Project name defaults to "agentic-chat-inspector".
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentic-chat-inspector
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- clinical-rag-mcp server (Module 2a) ---
# Optional NCBI API key for PubMed E-utils (raises rate limit from 3 to 10 req/s).
# Get one at https://www.ncbi.nlm.nih.gov/account/ — free.
NCBI_API_KEY=
NCBI_EUTILS_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
# HAPI FHIR R4 public sandbox — synthetic patients only.
HAPI_FHIR_BASE_URL=https://hapi.fhir.org/baseR4
